# App
NEXTAUTH_URL=https://matchday.example.com
NEXTAUTH_SECRET=
AUTH_SECRET=
APP_URL=https://matchday.example.com

# MongoDB
MONGODB_URI=mongodb://mongodb:27017/matchday

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=matchday-covers
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=https://matchday.example.com/api/storage

# SMTP (magic link)
# SMTP_CONSOLE=true — выводить magic link в консоль вместо отправки письма (локальная разработка)
# SMTP_LOG=true — подробные логи отправки в консоль контейнера app
SMTP_CONSOLE=false
SMTP_LOG=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
